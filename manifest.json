{
"manifest_version": 3,
"name": "Extension for Moodle+R",
"version": "1.0.0",
"description": "さらばmanaba+R、ベターレイアウトやシラバスの情報の自動取得、ダークモード、教職員向けモードなど様々な機能を搭載しております。 ",
"icons": {
  "16": "icons/icon16.png",
  "32": "icons/icon32.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
},
"permissions": [
"storage",
"tabs"
],
"host_permissions": [
"*://lms.ritsumei.ac.jp/*",
"*://syllabus.ritsumei.ac.jp/*"
],
"action": {
"default_popup": "popup.html",
"default_icon": {
  "16": "icons/icon16.png",
  "32": "icons/icon32.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
}
},
"background": {
"service_worker": "background.js"
},
"content_scripts": [
{
"matches": [
  "https://lms.ritsumei.ac.jp/*",
  "https://syllabus.ritsumei.ac.jp/*"
],
"css": ["content.css"],
"js": ["content.js"]
}
],
"web_accessible_resources": []
}
